---
// src/components/FAQ.astro
const faqs = [
  {
    question: "Tu es disponible pour combien de clients par mois ?",
    answer: "Je travaille avec 3 clients maximum par mois pour garantir la qualité et le délai de chaque projet."
  },
  {
    question: "Comment se passe le premier contact ?",
    answer: "Tu m'envoies un message, on discute de ton projet, et je te propose un devis sous 24h. Pas d'engagement."
  },
  {
    question: "Quels formats de fichiers tu acceptes ?",
    answer: "MP4, MOV, AVI — via Google Drive, WeTransfer ou Dropbox. Taille max : 10 Go par projet."
  },
  {
    question: "Tu peux créer les sous-titres en anglais aussi ?",
    answer: "Oui, je gère le sous-titrage en français et en anglais grâce aux outils IA de transcription automatique."
  },
  {
    question: "C'est quoi le 'workflow IA' exactement ?",
    answer: "J'utilise OpusClip pour les clips courts, Descript pour le montage par transcription, Captions.ai pour les sous-titres animés, et Leonardo.ai pour les miniatures. Résultat : plus de livrables, livré plus vite."
  }
];
---

<section class="section faq" id="faq">
  <div class="container">
    <div class="section-header">
      <span class="section-badge"><i data-lucide="help-circle"></i> FAQ</span>
      <h2 class="section-title">
        Questions <span class="gradient-text">fréquentes</span>
      </h2>
    </div>
    <div class="faq-list">
      {faqs.map((faq) => (
        <div class="faq-item glass">
          <button class="faq-question" aria-expanded="false">
            <span>{faq.question}</span>
            <i data-lucide="chevron-down" class="faq-chevron"></i>
          </button>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    border-radius: 20px;
    overflow: hidden;
  }

  .faq-question {
    width: 100%;
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: transparent;
    border: none;
    color: white;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    text-align: left;
    transition: all 0.3s ease;
  }

  .faq-question:hover { background: rgba(255, 255, 255, 0.03); }

  .faq-chevron {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
    opacity: 0.5;
  }

  .faq-item.active .faq-chevron { transform: rotate(180deg); opacity: 1; }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    background: rgba(255, 255, 255, 0.01);
  }

  .faq-item.active .faq-answer { max-height: 500px; padding: 0 2rem 2rem; }

  .faq-answer p { color: var(--text-dim); line-height: 1.6; }
</style>

<script>
  function initFAQ() {
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
      const question = item.querySelector('.faq-question');
      question?.addEventListener('click', () => {
        const isActive = item.classList.contains('active');
        faqItems.forEach(i => {
          i.classList.remove('active');
          i.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
        });
        if (!isActive) {
          item.classList.add('active');
          question.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  initFAQ();
  document.addEventListener('astro:after-swap', initFAQ);
</script>
