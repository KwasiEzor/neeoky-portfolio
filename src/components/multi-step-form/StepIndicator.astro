---
interface Step {
  number: number;
  title: string;
  description: string;
}

const steps: Step[] = [
  { number: 1, title: 'Service', description: 'Choisissez vos services' },
  { number: 2, title: 'Pack', description: 'Sélectionnez votre offre' },
  { number: 3, title: 'Projet', description: 'Décrivez votre projet' },
  { number: 4, title: 'Contact', description: 'Vos coordonnées' },
  { number: 5, title: 'Récap', description: 'Validation finale' },
];
---

<div class="step-indicator">
  <!-- Mobile: Progress bar -->
  <div class="mobile-progress">
    <div class="progress-bar">
      <div class="progress-fill" id="progress-fill"></div>
    </div>
    <p class="progress-text" id="progress-text">Étape 1 sur 5</p>
  </div>

  <!-- Desktop: Full step indicator -->
  <div class="desktop-steps">
    {steps.map((step, index) => (
      <div class="step-item" data-step={step.number}>
        <div class="step-connector" data-step={step.number}>
          {index < steps.length - 1 && <div class="connector-line" />}
        </div>

        <button
          type="button"
          class="step-button"
          data-step-btn={step.number}
          aria-label={`Aller à l'étape ${step.number}: ${step.title}`}
        >
          <div class="step-circle">
            <span class="step-number">{step.number}</span>
            <svg class="step-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>

          <div class="step-content">
            <span class="step-title">{step.title}</span>
            <span class="step-description">{step.description}</span>
          </div>
        </button>
      </div>
    ))}
  </div>
</div>

<style>
  .step-indicator {
    margin-bottom: 2rem;
  }

  /* Mobile Progress Bar */
  .mobile-progress {
    display: block;
  }

  .progress-bar {
    width: 100%;
    height: 8px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #a855f7, #ec4899);
    border-radius: 9999px;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    width: 20%;
  }

  .progress-text {
    text-align: center;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  /* Desktop Steps */
  .desktop-steps {
    display: none;
  }

  @media (min-width: 768px) {
    .mobile-progress {
      display: none;
    }

    .desktop-steps {
      display: flex;
      justify-content: space-between;
      position: relative;
    }

    .step-item {
      flex: 1;
      position: relative;
    }

    .step-connector {
      position: absolute;
      top: 20px;
      left: 50%;
      width: 100%;
      z-index: 0;
    }

    .step-item:last-child .step-connector {
      display: none;
    }

    .connector-line {
      height: 2px;
      background: rgba(255, 255, 255, 0.1);
      transition: background 0.3s ease;
    }

    .step-item.completed .connector-line,
    .step-item.active .connector-line {
      background: linear-gradient(90deg, #a855f7, #ec4899);
    }

    .step-button {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      transition: opacity 0.2s;
      width: 100%;
    }

    .step-button:hover:not(:disabled) {
      opacity: 0.8;
    }

    .step-button:disabled {
      cursor: not-allowed;
      opacity: 0.5;
    }

    .step-circle {
      position: relative;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.05);
      border: 2px solid rgba(255, 255, 255, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .step-item.active .step-circle {
      background: linear-gradient(135deg, #a855f7, #ec4899);
      border-color: transparent;
      transform: scale(1.1);
      box-shadow: 0 4px 20px rgba(168, 85, 247, 0.4);
    }

    .step-item.completed .step-circle {
      background: linear-gradient(135deg, #22c55e, #16a34a);
      border-color: transparent;
    }

    .step-number {
      font-size: 1rem;
      font-weight: 600;
      color: white;
      transition: opacity 0.2s;
    }

    .step-item.completed .step-number {
      opacity: 0;
    }

    .step-check {
      position: absolute;
      width: 20px;
      height: 20px;
      color: white;
      opacity: 0;
      transform: scale(0);
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .step-item.completed .step-check {
      opacity: 1;
      transform: scale(1);
    }

    .step-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .step-title {
      font-size: 0.875rem;
      font-weight: 600;
      color: white;
      margin-bottom: 0.125rem;
    }

    .step-description {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.5);
      transition: color 0.2s;
    }

    .step-item.active .step-description {
      color: rgba(255, 255, 255, 0.8);
    }
  }
</style>

<script>
  import { currentStep, totalSteps, stepValidation } from '../../stores/formStore';

  // Update indicator when step changes
  currentStep.subscribe((step) => {
    updateIndicator(step);
  });

  // Update when validation changes
  stepValidation.subscribe(() => {
    const current = currentStep.get();
    updateIndicator(current);
  });

  function updateIndicator(current: number) {
    const total = totalSteps.get();
    const validation = stepValidation.get();

    // Update mobile progress
    const progressFill = document.getElementById('progress-fill');
    const progressText = document.getElementById('progress-text');

    if (progressFill) {
      const percent = (current / total) * 100;
      progressFill.style.width = `${percent}%`;
    }

    if (progressText) {
      progressText.textContent = `Étape ${current} sur ${total}`;
    }

    // Update desktop steps
    const stepItems = document.querySelectorAll('.step-item');
    const stepButtons = document.querySelectorAll('[data-step-btn]');

    stepItems.forEach((item, index) => {
      const stepNum = index + 1;

      // Remove all states
      item.classList.remove('active', 'completed');

      // Add current state
      if (stepNum === current) {
        item.classList.add('active');
      } else if (stepNum < current || validation[stepNum]) {
        item.classList.add('completed');
      }
    });

    // Enable/disable step buttons based on validation
    stepButtons.forEach((btn) => {
      const stepNum = parseInt((btn as HTMLElement).dataset.stepBtn || '0');
      const button = btn as HTMLButtonElement;

      // Can navigate to:
      // - Previous steps
      // - Current step
      // - Next step if current is valid
      const canNavigate =
        stepNum < current ||
        stepNum === current ||
        (stepNum === current + 1 && validation[current]);

      button.disabled = !canNavigate;
    });
  }

  // Handle step button clicks
  document.querySelectorAll('[data-step-btn]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const stepNum = parseInt((btn as HTMLElement).dataset.stepBtn || '0');
      if (stepNum) {
        currentStep.set(stepNum);
      }
    });
  });

  // Initialize
  updateIndicator(currentStep.get());
</script>
