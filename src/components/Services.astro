---
// src/components/Services.astro
import { useSanityClient } from "astro-sanity";

// Fallback data if Sanity is empty
const fallbackServices = [
  {
    name: "Starter",
    price: "80€",
    unit: "/vidéo",
    icon: "🎬",
    features: [
      "Montage complet jusqu'à 15 min",
      "Sous-titres automatiques retravaillés",
      "Musique de fond sélectionnée",
      "Export YouTube + Reels",
      "Livraison 48h"
    ],
    isPopular: false,
    ctaText: "Choisir Starter"
  },
  {
    name: "Pro IA",
    price: "180€",
    unit: "/vidéo",
    icon: "🤖",
    features: [
      "Tout le pack Starter",
      "3 clips courts Reels/Shorts",
      "Miniature optimisée (IA + Canva)",
      "Suppression auto des silences",
      "Livraison 24h · 1 révision incluse"
    ],
    isPopular: true,
    ctaText: "Choisir Pro IA"
  },
  {
    name: "Mensuel",
    price: "600€",
    unit: "/mois",
    icon: "🚀",
    features: [
      "4 vidéos Pro IA par mois",
      "Priorité absolue sur les délais",
      "12 clips courts inclus",
      "4 miniatures incluses",
      "Suivi stratégique contenu offert"
    ],
    isPopular: false,
    ctaText: "Choisir Mensuel"
  }
];

// Fetch live data from Sanity
let liveServices = [];
try {
  liveServices = await useSanityClient().fetch('*[_type == "service"] | order(price asc)');
} catch (e) {
  console.error("Sanity fetch failed, using fallback data.");
}

const displayServices = liveServices.length > 0 ? liveServices : fallbackServices;

const addons = [
  { price: "25€", name: "Miniature seule" },
  { price: "60€", name: "Pack 5 clips courts" },
  { price: "30€", name: "Sous-titrage seul" },
  { price: "80€", name: "Audit chaîne YouTube" },
  { price: "500€+", name: "Workflow IA complet" }
];
---

<section class="section services" id="services">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">
        <i data-lucide="package"></i>
        Offres
      </span>
      <h2 class="section-title">
        Mes <span class="gradient-text">services</span>
      </h2>
      <p class="section-subtitle">
        Des offres claires, sans surprise. Choisis ce qui te convient.
      </p>
    </div>

    <div class="services-grid">
      {displayServices.map((service) => (
        <div class={`service-card glass ${service.isPopular ? 'featured' : ''}`}>
          {service.isPopular && <span class="popular-badge">Populaire</span>}
          <div class="service-card-header">
            <span class="service-icon">{service.icon || '✨'}</span>
            <h3 class="service-name">{service.name}</h3>
            <div class="service-price">{service.price}<span>{service.unit || ''}</span></div>
          </div>
          <ul class="service-features">
            {service.features && service.features.map((feature) => (
              <li>
                <i data-lucide="check"></i>
                {feature}
              </li>
            ))}
          </ul>
          <a href="/contact" class={`btn ${service.isPopular ? 'btn-primary' : 'btn-ghost'} btn-full`}>
            {service.ctaText || 'Choisir'}
          </a>
        </div>
      ))}
    </div>

    <div class="addons">
      <h3 class="addons-title">Add-ons à la carte</h3>
      <div class="addons-grid">
        {addons.map((addon) => (
          <div class="addon glass">
            <span class="addon-price">{addon.price}</span>
            <span class="addon-name">{addon.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Same styles as before */
  .section { padding: 8rem 0; }
  .section-header { text-align: center; margin-bottom: 4rem; }
  .section-badge { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 100px; font-size: 0.85rem; font-weight: 500; color: var(--accent); margin-bottom: 1.5rem; }
  .section-title { font-family: 'Syne', sans-serif; font-size: 3rem; font-weight: 800; margin-bottom: 1rem; }
  .section-subtitle { font-size: 1.1rem; color: var(--text-dim); max-width: 600px; margin: 0 auto; }
  .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-bottom: 4rem; }
  .service-card { position: relative; padding: 3rem 2rem; border-radius: 24px; display: flex; flex-direction: column; transition: all 0.4s ease; }
  .service-card.glass { background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); }
  .service-card.featured { background: rgba(168, 85, 247, 0.05); border-color: rgba(168, 85, 247, 0.2); transform: scale(1.05); }
  .popular-badge { position: absolute; top: 1.5rem; right: 1.5rem; background: var(--primary); padding: 0.25rem 0.75rem; border-radius: 100px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
  .service-card-header { margin-bottom: 2rem; }
  .service-icon { font-size: 2.5rem; display: block; margin-bottom: 1rem; }
  .service-name { font-family: 'Syne', sans-serif; font-size: 1.75rem; margin-bottom: 0.5rem; }
  .service-price { font-size: 2.5rem; font-weight: 800; }
  .service-price span { font-size: 1rem; color: var(--text-dim); font-weight: 400; }
  .service-features { list-style: none; margin-bottom: 3rem; flex-grow: 1; }
  .service-features li { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; color: var(--text-dim); font-size: 0.95rem; }
  .service-features li i { color: var(--accent); width: 18px; }
  .btn-full { width: 100%; justify-content: center; }
  .addons { background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 32px; padding: 3rem; text-align: center; }
  .addons-title { font-family: 'Syne', sans-serif; margin-bottom: 2rem; font-size: 1.5rem; }
  .addons-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; }
  .addon { padding: 1rem 1.5rem; border-radius: 100px; display: flex; align-items: center; gap: 1rem; border: 1px solid rgba(255, 255, 255, 0.05); }
  .addon-price { font-weight: 700; color: var(--primary); }
  .addon-name { font-weight: 500; font-size: 0.9rem; }
  @media (max-width: 768px) { .service-card.featured { transform: none; } .section-title { font-size: 2.5rem; } }
</style>
